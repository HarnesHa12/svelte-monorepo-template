{
  "name": "svelte-monorepo-template",
  "private": true,
  "packageManager": "bun@1.3.11",
  "scripts": {
    "build": "SKIP_ENV_VALIDATION=1 turbo run build",
    "dev": "dotenv -- turbo run dev",
    "db:migrate": "dotenv -- turbo run db:migrate",
    "db:deploy": "dotenv -- turbo run db:deploy",
    "db:generate": "SKIP_ENV_VALIDATION=1 turbo run db:generate",
    "db:studio": "dotenv -- turbo run db:studio",
    "db:push": "dotenv -- turbo run db:push",
    "auth:generate": "dotenv -- turbo run auth:generate",
    "format": "biome format",
    "format:prisma": "SKIP_ENV_VALIDATION=1 turbo run format:prisma",
    "format:fix": "bun run format:prisma && biome format --write",
    "lint": "biome lint",
    "lint:fix": "biome lint --fix",
    "typecheck": "turbo run typecheck",
    "sherif": "bunx sherif@latest",
    "sherif:fix": "bunx sherif@latest --fix",
    "postinstall": "bun run sherif"
  },
  "workspaces": [
    "apps/*",
    "packages/*",
    "tools/*"
  ],
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@types/bun": "^1.3.13",
    "dotenv-cli": "^11.0.0",
    "turbo": "^2.9.6",
    "typescript": "^6.0.3"
  }
}
