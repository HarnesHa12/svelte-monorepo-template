{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noUncheckedIndexedAccess": true,
    "verbatimModuleSyntax": true,
    "noEmit": true,
    "rootDir": "src",
    "outDir": "dist",
    "lib": ["ESNext", "DOM"],
    "types": ["bun"]
  },
  "include": ["src"],
  "exclude": ["node_modules"]
}
